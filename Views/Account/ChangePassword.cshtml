@model ChangePasswordViewModel

@{
    Layout = "_LearningLayout";
}

<section class="page-panel">
    <p class="eyebrow">Security</p>
    <h2>Change your password</h2>
</section>

<section class="content-card compact-card">
    <form asp-action="ChangePassword" method="post" class="form-stack">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field">
            <label asp-for="CurrentPassword"></label>
            <input asp-for="CurrentPassword" />
            <span asp-validation-for="CurrentPassword" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" />
            <span asp-validation-for="NewPassword" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>

        <div class="button-row">
            <button type="submit" class="primary-button">Update Password</button>
            <a asp-action="Profile" class="ghost-button">Back</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
