@model PracticeLogDetailsViewModel

<section class="page-panel">
    <p class="eyebrow">@Model.TrackName</p>
    <h2>@Model.SessionTitle</h2>
    <p class="section-copy">@Model.Reflection</p>
    <div class="mini-stats">
        <span>Lesson: @Model.LessonTitle</span>
        <span>Activity: @Model.ActivityType</span>
        <span>Practiced: @Model.PracticedOn.ToString("dd MMM yyyy")</span>
        <span>Review in @ViewBag.ReviewWindow day(s)</span>
    </div>
</section>

<section class="card-grid two-up">
    <article class="content-card">
        <h3>Session Metrics</h3>
        <div class="mini-stats mini-stats--stack">
            <span>Accuracy: @Model.AccuracyScore%</span>
            <span>Duration: @Model.DurationMinutes min</span>
            <span>Next review: @Model.NextReviewDate.ToString("dd MMM yyyy")</span>
            <span>New expression: @Model.NewExpression</span>
        </div>
    </article>

    <article class="content-card">
        <h3>Actions</h3>
        <div class="button-stack">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="primary-button">Edit Practice Log</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="ghost-button ghost-button--danger">Delete Practice Log</a>
            <a asp-controller="Lessons" asp-action="Details" asp-route-id="@Model.LessonId" class="ghost-button">Back to Lesson</a>
        </div>
    </article>
</section>
