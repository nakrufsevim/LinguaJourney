@model LessonFormViewModel

<section class="page-panel">
    <p class="eyebrow">Create</p>
    <h2>Plan a new lesson</h2>
</section>

<section class="content-card">
    <form asp-action="Create" method="post" class="form-grid">
        <partial name="_Form" model="Model" />

        <div class="form-span-2 button-row">
            <button type="submit" class="primary-button">Create Lesson</button>
            <a asp-action="Index" class="ghost-button">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
